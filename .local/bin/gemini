#!/usr/bin/env python3
import sys
import os
import google.generativeai as genai
from pathlib import Path

# Load API key
api_key_file = Path.home() / ".config" / "gemini" / "api_key"
if not api_key_file.exists():
    print("❌ API key not found. Run: gemini-setup-key", file=sys.stderr)
    sys.exit(1)

api_key = api_key_file.read_text().strip()
genai.configure(api_key=api_key)

model = genai.GenerativeModel('gemini-2.0-flash-exp')

def main():
    if len(sys.argv) < 2 and sys.stdin.isatty():
        print("Usage: gemini <prompt> or pipe input", file=sys.stderr)
        sys.exit(1)
    
    # Check for piped input
    if not sys.stdin.isatty():
        piped_input = sys.stdin.read()
        prompt = " ".join(sys.argv[1:]) + "\n\n" + piped_input if len(sys.argv) > 1 else piped_input
    else:
        prompt = " ".join(sys.argv[1:])
    
    try:
        response = model.generate_content(prompt)
        print(response.text)
    except Exception as e:
        print(f"❌ Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
